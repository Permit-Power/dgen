{
  "name": "dgen",
  "dockerComposeFile": "../docker/docker-compose.yml",
  "service": "dgen",
  "workspaceFolder": "/workspaces/dgen",
  "remoteUser": "dgen",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/dg3n/bin/python"
      }
    }
  }
}
